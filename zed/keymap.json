// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "VimControl && !(vim_mode == insert)",
    "bindings": {
      //rebind macro binds
      "q": null,
      "m": "vim::ToggleRecord",

      //navigate between panes
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",
      "space w q": "pane::CloseActiveItem",

      //split pane settings
      "space s h": "pane::SplitLeft",
      "space s j": "pane::SplitDown",
      "space s k": "pane::SplitUp",
      "space s l": "pane::SplitRight",

      //fuzzy finder
      "space f f": "file_finder::Toggle",

      //terminal keybinds
      "alt-t": "terminal_panel::Toggle",
      "space t n": "workspace::NewTerminal",
      "space a": "agent::ToggleFocus",

      //file manager binds
      "space e": "project_panel::ToggleFocus",
    },
  },

  //file manager binds from within file manager
  {
    "context": "ProjectPanel",
    "bindings": {
      //clear enter keybind to prevent opening files on enter
      "enter": null,

      //custom open file keybinds
      "enter": "project_panel::OpenSplitVertical",

      //binds for file actions
      "r": "project_panel::Rename",
      "D": "project_panel::Delete",
      "f": "project_panel::NewDirectory",
      "d": "project_panel::NewDirectory",

      //close file manager
      "space e": "workspace::CloseActiveDock",
    },
  },

  // resize window split
  {
    "context": "VimControl && !(vim_mode == insert) && Pane",
    "bindings": {
      "space h": "vim::ResizePaneLeft",
      "space j": "vim::ResizePaneDown",
      "space k": "vim::ResizePaneUp",
      "space l": "vim::ResizePaneRight",
    },
  },

  //close pane(window buffer) binds
  {
    "context": "VimControl && !(vim_mode == insert) && Pane",
    "bindings": {
      "q": null,
      "space w q": "pane::CloseActiveItem",
    },
  },

  //close agent tab from within Agent Message box
  {
    "context": "VimControl && !(vim_mode == insert)",
    "bindings": {
      "space a": "workspace::CloseActiveDock",
    },
  },

  //terminal binds from within terminal
  {
    "context": "Terminal",
    "bindings": {
      "alt-q": "pane::CloseActiveItem",
      "alt-t": "workspace::NewTerminal",
    },
  },
]
